  "labels": [
    {"text": "Вітаю у гра Gravity Shift!", "x": 250, "y": 3570, "size": 35, "color": [255, 255, 255], "bg_alpha": 150, "nomer": "0"},
    {"text": "Гра спроєктована як випускна робота, та перероджена в ЛОГІРЕЙС2026!", "x": 130, "y": 3610, "size": 20, "color": [255, 255, 255], "bg_alpha": 150, "nomer": "1"},
    {"text": "1. В для керування дано W/↑, A/←, S/↓, D/→", "x": 180, "y": 3660, "size": 25, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "2"},
    {"text": "2. Долання паркуру завдяки стрибку", "x": 1440, "y": 3530, "size": 25, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "3"},
    {"text": "та швидке падіння протилежною кнопкою.", "x": 1440, "y": 3560, "size": 20, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "4"},
    {"text": "3. Портали при перетинанні з гравцем, міняють йому гравітацію. ", "x": 2750, "y": 3750, "size": 20, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "5"},
    {"text": "І вони якось дуже дивно схожі до гравця за матераєю... ", "x": 2785, "y": 3772, "size": 17, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "6"},
    {"text": "4. Портали є у всі сторони, тобі пора нагору... ", "x": 3570, "y": 3875, "size": 22, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "7"},
    {"text": "Лабалаторія тут закунчується,", "x": 4330, "y": 3660, "size": 20, "color": [255, 255, 255], "bg_alpha": 130, "nomer": "8"},
    {"text": "здається тут немає ввиходу... ", "x": 4330, "y": 3682, "size": 19, "color": [255, 255, 255], "bg_alpha": 130, "nomer": "9"},
    {"text": "Це шанс! Каміння схоже на паркур", "x": 5480, "y": 3650, "size": 20, "color": [255, 255, 255], "bg_alpha": 130, "nomer": "10"},
    {"text": "5. Ця дивна приблуда збереження. (R) ", "x": 5380, "y": 3600, "size": 25, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "11"},
    {"text": "6. Використовуй (F L або Shift)  ", "x": 5400, "y": 2845, "size": 25, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "12"},
    {"text": "Щоб залипати і скасовувати падіння", "x": 5400, "y": 2875, "size": 25, "color": [205, 255, 235], "bg_alpha": 150, "nomer": "13"}
  ]
