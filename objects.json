  "labels": [
    {"text": "ПРИВІТ!", "x": 150, "y": 4710, "size": 40, "color": [155, 255, 155], "bg_alpha": 120, "nomer": "0"},
    {"text": "Вітаю y rpi Gravity Shift (Боді Ніколи).", "x": 90, "y": 4750, "size": 30, "color": [155, 155, 255], "bg_alpha": 120, "nomer": "1"},
    {"text": "Цей проєкт запікався дуже довго i лагідно тому можу лише побажати приємної гри!", "x": 30, "y": 4785, "size": 20, "color": [255, 255, 255], "bg_alpha": 120, "nomer": "2"},
    {"text": "Перший час в rpi вас буде супровожувувати підказки i фішки.", "x": 250, "y": 4810, "size": 17, "color": [222, 222, 255], "bg_alpha": 120, "nomer": "3"},
    {"text": "1. Для pyxy юзайте стрілки a6o WASD", "x": 100, "y": 5050, "size": 35, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "4"},
    {"text": "2. Стрибок залежить від гравітації          Швидке падіння        ", "x": 1250, "y": 5050, "size": 35, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "5"},
    {"text": "   Але зараз це кнопка ↑ a6o W                   Протилежна кнопка ↓ a6o S ", "x": 1250, "y": 5090, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "6"},
    {"text": "Вікно гри адаптивне, можна змінювати його розміри", "x": 1160, "y": 4655, "size": 25, "color": [255, 255, 255], "bg_alpha": 60, "nomer": "7"},
    {"text": "a6o навіть відкрити його на весь екран - F11", "x": 1160, "y": 4685, "size": 25, "color": [255, 255, 255], "bg_alpha": 60, "nomer": "8"},
    {"text": "3. Знайомся гравітаційний портал ВГОРУ та ВНИЗ", "x": 2700, "y": 5050, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "9"},
    {"text": "Кнопка TAB міняє гравця", "x": 2950, "y": 4850, "size": 27, "color": [255, 255, 255], "bg_alpha": 60, "nomer": "10"},
    {"text": "4. Портали є y всіх напрямках!", "x": 3650, "y": 5050, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "11"},
    {"text": "Кнопка M (англ) міняє керування з o6ox типів", "x": 3790, "y": 4685, "size": 20, "color": [255, 255, 255], "bg_alpha": 30, "nomer": "12"},
    {"text": "5. Також існують портали як плити.", "x": 4800, "y": 5050, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "13"},
    {"text": "5. Твоя нова точка збереження!", "x": 5600, "y": 5050, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "14"},
    {"text": "Доторкнися до неї і за кнопкою R переродися.", "x": 5500, "y": 5080, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "15"},
    {"text": "6. Обережно слизько! (Це лід)", "x": 6400, "y": 5050, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "16"},
    {"text": "7. УВАГА, смертельна небезпека! (червоний блок)", "x": 7000, "y": 5050, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "17"},
    {"text": "8. КІНЕЦЬ? (червоний блок, це двері)", "x": 8000, "y": 5050, "size": 30, "color": [255, 255, 255], "bg_alpha": 100, "nomer": "18"}
